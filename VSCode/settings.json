{
  "window.autoDetectColorScheme": true,
  "window.zoomLevel": 0,
  "workbench.activityBar.location": "top",
  "workbench.browser.showInTitleBar": false,
  "workbench.editor.empty.hint": "hidden",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.openInAgents.enabled": false,
  "workbench.preferredDarkColorTheme": "One Dark Pro Night Flat",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.startupEditor": "none",
  "workbench.welcomePage.walkthroughs.openOnInstall": false,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.detectIndentation": false,
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.insertSpaces": true,
  "editor.minimap.enabled": false,
  "editor.renderLineHighlight": "none",
  "editor.scrollBeyondLastLine": false,
  "editor.stickyScroll.enabled": false,
  "[axaml]": {
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.wordWrap": "on"
  },
  "[xml]": {
    "editor.tabSize": 2
  },
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "code-runner.clearPreviousOutput": true,
  "code-runner.ignoreSelection": true,
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.executorMap": {
    "c": "cd $dirWithoutTrailingSlash ; if (!(Test-Path 'build')) { New-Item -ItemType Directory -Path 'build' | Out-Null } ; gcc $fileName -Wall -Wextra -std=c11 -o build\\$fileNameWithoutExt.exe ; if ($?) { Start-Process -FilePath 'cmd.exe' -ArgumentList \"/C `\"build\\$fileNameWithoutExt.exe`\" & pause\" -Wait } ; Remove-Item -Path 'build' -Recurse -Force -ErrorAction SilentlyContinue",
    "cpp": "cd $dirWithoutTrailingSlash ; if (!(Test-Path 'build')) { New-Item -ItemType Directory -Path 'build' | Out-Null } ; g++ $fileName -Wall -Wextra -std=c++17 -o build\\$fileNameWithoutExt.exe ; if ($?) { Start-Process -FilePath 'cmd.exe' -ArgumentList \"/C `\"build\\$fileNameWithoutExt.exe`\" & pause\" -Wait } ; Remove-Item -Path 'build' -Recurse -Force -ErrorAction SilentlyContinue"
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.axaml": "${capture}.axaml.cs",
    "*.db": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.s3db": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.sqlite": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.ts": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "tsconfig.json": "tsconfig.*.json"
  },
  "avalonia.preview.autoOpen": false,
  "dotnet.codeLens.enableReferencesCodeLens": false,
  "explorer.compactFolders": false,
  "terminal.integrated.initialHint": false,
  "material-icon-theme.folders.associations": {
    "account": "admin",
    "accounts": "admin",
    "catalog": "app",
    "catalogue": "app",
    "factories": "generator",
    "factory": "generator",
    "login": "keys",
    "modal": "messages",
    "modals": "messages",
    "model": "interface",
    "models": "interface",
    "navigationBar": "routes",
    "obj": "dist",
    "page": "layout",
    "pages": "layout",
    "processor": "core",
    "processors": "core",
    "purchase": "cart",
    "purchases": "cart",
    "register": "form",
    "sale": "store",
    "sell": "store",
    "setting": "config",
    "settings": "config",
    "sidebar": "ui",
    "sidebars": "ui",
    "state": "bloc",
    "states": "bloc",
    "statistic": "constant",
    "statistics": "constant",
    "style": "theme",
    "styles": "theme",
    "viewmodel": "controller",
    "viewmodels": "controller"
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "workbench.editor.enablePreview": false
}
